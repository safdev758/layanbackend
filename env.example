# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/layan_db

# JWT Configuration
SECRET_KEY=your_super_secret_jwt_key_here_change_in_production

# Optional: Email Configuration (for OTP sending)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# Optional: SMS Configuration (for OTP sending)
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret

# Optional: File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Optional: Redis Configuration (for caching/sessions)
REDIS_URL=redis://localhost:6379

# Optional: WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_CONNECTION_TIMEOUT=45000
